corrected_Txtilde_Sk_FINAL[[1]] <- as.matrix(nearPD(corrected_Txtilde_Sk[[1]], corr = FALSE)$mat)
fit <- Separate.fit(Tx, Tvax, lambda.list = lambda.list)
